# Configuration DeepBook pour Sui
# Copiez ce fichier vers .env et modifiez les valeurs selon vos besoins

# Adresse du package DeepBook publié sur Sui
DEEPBOOK_PACKAGE_ADDRESS=0xdee9

# Réseau Sui (mainnet, testnet, devnet)
SUI_NETWORK=testnet

# URL RPC Sui (optionnel)
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Token DEEP address
DEEP_TOKEN_ADDRESS=0xdeeb7a4662eec9f2f3def03fb937a663dddaa2e215b8078a284d026b7946c270

# Configuration Git pour DeepBook
DEEPBOOK_GIT_URL=https://github.com/MystenLabs/sui.git
DEEPBOOK_GIT_SUBDIR=crates/sui-framework/packages/deepbook
DEEPBOOK_GIT_REV=framework/testnet

# Turbos Versioned Object ID
# Objet partagé unique représentant la version du protocole Turbos
# Mainnet: 0xa5a0c25c79e428eba04fb98b3fb2a34db45ab26d4c8faf0d7e39d66a63891e64
# Testnet: À rechercher dans l'explorateur Sui testnet
TURBOS_VERSIONED_OBJECT_ID=0xa5a0c25c79e428eba04fb98b3fb2a34db45ab26d4c8faf0d7e39d66a63891e64

# Sui Clock Object ID (généralement le même sur tous les réseaux)
SUI_CLOCK_OBJECT_ID=0x6

